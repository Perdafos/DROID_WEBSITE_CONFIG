# ── Stream type ────────────────────────────────────
# "http" — DroidCam HTTP MJPEG source (default)
# "rtsp" — RTSP camera via FFmpeg transcoding
STREAM_TYPE=http

# ── HTTP source (DroidCam) ─────────────────────────
# Dipakai kalau STREAM_TYPE=http
DROIDCAM_URL=http://192.168.1.100:4747/video

# ── RTSP source (camera IP/nvr) ────────────────────
# Dipakai kalau STREAM_TYPE=rtsp
RTSP_URL=rtsp://user:password@192.168.1.200:554/stream1
RTSP_TRANSPORT=tcp      # tcp | udp (default: tcp)
RTSP_FPS=15             # output framerate (default: 15)
RTSP_SIZE=640x480       # output resolution (default: 640x480)
RTSP_QUALITY=3          # JPEG quality 1-31, lower=better (default: 3)
FFMPEG_PATH=ffmpeg      # path to ffmpeg binary

# ── Server config ──────────────────────────────────
PORT=3000
HOST=0.0.0.0

# ── Basic auth (optional) ──────────────────────────
# USERNAME=admin
# PASSWORD=rahasia123

# ── Relay mode ─────────────────────────────────────
# "proxy" — server fetches & relays (default)
# "direct" — server tells viewers the source IP
RELAY_MODE=proxy
